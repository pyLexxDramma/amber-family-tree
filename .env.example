# OpenAI API Key для голосового помощника (AiShell на /app).
# Скопируйте в .env.local и подставьте свой ключ:
# VITE_OPENAI_API_KEY=sk-proj-...
VITE_OPENAI_API_KEY=

# Lovable Cloud: VITE_SUPABASE_URL подставляется автоматически, base = .../functions/v1/openai-proxy.
# Локально: fallback на /api/openai (Vite proxy). Опционально — явный override:
# VITE_OPENAI_PROXY_URL=https://...supabase.co/functions/v1/openai-proxy

# Информационная архитектура из видения заказчика (нижняя навигация и стартовый экран /classic).
# VITE_VISION_IA_NAV=true — табы: Семья, История, Создать, Коллекции, Сообщения, Ателье.
# VITE_VISION_IA_HOME=messages — при VITE_VISION_IA_NAV=true вход на /classic ведёт на хаб сообщений (как в концепции MVP).
# VITE_VISION_IA_NAV=
# VITE_VISION_IA_HOME=

# На Fornex: положите копию нужных VITE_* в корень репозитория на сервере как .env.deploy
# (не коммитить). Скрипт deploy-fornex.sh подхватит файл перед npm run build.
